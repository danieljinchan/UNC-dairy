# PostgreSQL connection string used by Prisma.
#
# On Vercel: add a Neon Postgres database from the project's Storage tab
# (Marketplace). Vercel's Neon integration sets DATABASE_URL automatically —
# you do NOT need to configure this manually for the deployed app.
#
# For local development, point this at a local Postgres instance or a
# Neon development branch:
DATABASE_URL="postgresql://user:password@localhost:5432/predictive_maintenance?schema=public"
